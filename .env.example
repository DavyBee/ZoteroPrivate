# Copy this file to ".env" and fill in the values, or let setup.command copy it
# for you. The real .env is gitignored — keep your keys out of version control.

# ── Zotero (required to upload) ──────────────────────────────────────────────
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=group            # "group" (shared lab library) or "user"
ZOTERO_COLLECTION_KEY=               # optional — a specific collection to add to

# ── Anthropic / Claude (LLM fallback stage; optional but recommended) ────────
ANTHROPIC_API_KEY=
LLM_MODEL=                           # optional — blank uses the built-in default

# ── Turso (hosted SQLite — ONLY for cloud deploy; leave blank for local dev) ─
# Local development uses a plain SQLite file (zotero_database.db) and needs
# NEITHER of these. Set both only on the hosted deploy so the data survives the
# cloud's ephemeral filesystem. See WEBSITE_TODO.md / README for the runbook.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
